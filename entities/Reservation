{
  "name": "Reservation",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nom et pr\u00e9nom du prospect"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email du prospect"
    },
    "phone": {
      "type": "string",
      "description": "Num\u00e9ro de t\u00e9l\u00e9phone"
    },
    "meeting_type": {
      "type": "string",
      "enum": [
        "visite",
        "appel"
      ],
      "description": "Type de rendez-vous"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date du rendez-vous"
    },
    "time_slot": {
      "type": "string",
      "description": "Cr\u00e9neau horaire (ex: 10:00)"
    },
    "message": {
      "type": "string",
      "description": "Message ou commentaire du prospect"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled"
      ],
      "default": "pending",
      "description": "Statut de la r\u00e9servation"
    }
  },
  "required": [
    "name",
    "email",
    "meeting_type",
    "date",
    "time_slot"
  ]
}